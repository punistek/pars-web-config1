{
  "version": 1,
  "minimumAppVersion": 1,
  "maintenance": false,
  "maintenanceMessage": "",

  "sites": [

    {
      "id": "hdfilmizle",

      "enabled": true,

      "priority": 1,

      "domain": "https://hdfilmizle.now",

      "resolver": "vidrame",

      "iframeSelector": "iframe.vpx",

      "playSelector": ".play-that-video",

      "masterRegex": "master\\.m3u8",

      "headers": {
        "Referer": "https://hdfilmizle.now/"
      }
    },

    {
      "id": "filmmakinesi",

      "enabled": true,

      "priority": 2,

      "domain": "https://filmmakinesi.to",

      "resolver": "rapid_close",

      "iframeSelector": "iframe",

      "playSelector": ".play-button",

      "masterRegex": "master\\.m3u8|index.*\\.m3u8",

      "headers": {
        "Referer": "https://filmmakinesi.to/"
      }
    }

  ]
}
